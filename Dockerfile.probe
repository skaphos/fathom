# Build the probe binary.
FROM golang:1.26 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.mod
COPY go.sum go.sum
RUN go mod download

COPY cmd/probe/ cmd/probe/

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} go build -trimpath -ldflags="-s -w -buildid=" -o probe ./cmd/probe

# Package only the static probe binary.
FROM scratch
COPY --from=builder /workspace/probe /probe
USER 65532:65532

ENTRYPOINT ["/probe"]
